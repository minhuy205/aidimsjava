      ]
    },
    {
      "name": "DICOM Analysis - Success",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "src": "tests/sample.dcm",
              "type": "file"
            },
            {
              "key": "message",
              "value": "Phân tích hình ảnh DICOM này",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/api/dicom/analyze",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "dicom",
            "analyze"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code !== 200) {",
              "    console.log(\"❌ DICOM Success Test Failed! Server response body:\", pm.response.text());",
              "}",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response contains success status and analysis text\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"success\");",
              "    pm.expect(jsonData.analysisText).to.be.a(\"string\");",
              "    pm.expect(jsonData.dicomImageBase64).to.include(\"data:image/jpeg;base64,\");",
              "    pm.expect(jsonData.metadata).to.not.be.null;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "DICOM Analysis - Failure (Invalid Extension)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "src": "tests/sample_bad.txt",
              "type": "file"
            },
            {
              "key": "message",
              "value": "Phân tích hình ảnh DICOM này",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/api/dicom/analyze",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "dicom",
            "analyze"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 400\", function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "pm.test(\"Response status is error and error message contains Chỉ hỗ trợ file .dcm\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"error\");",
              "    pm.expect(jsonData.analysisText).to.include(\"Chỉ hỗ trợ file .dcm\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
